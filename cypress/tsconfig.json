{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "sourceMap": false,
    "types": ["cypress", "node"],
    "isolatedModules": false,
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true
  },
  "include": ["**/*.ts"]
}
